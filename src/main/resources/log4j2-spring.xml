<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Properties>
        <Property name="LOG_FILE">${spring:logging.file.name:-logs/avlija.log}</Property>
        <Property name="CONSOLE_PATTERN">%d{HH:mm:ss} %highlight{%-5level}{FATAL=red, ERROR=red, WARN=yellow, INFO=green, DEBUG=cyan} %cyan{%c{1}} - %msg%n</Property>
        <Property name="FILE_PATTERN">%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n</Property>
    </Properties>

    <Appenders>

        <!-- Console -->
        <Console name="CONSOLE" target="SYSTEM_OUT">
            <PatternLayout pattern="${CONSOLE_PATTERN}" disableAnsi="false"/>
        </Console>

        <!-- Rolling file - new file each day, keep 30 days -->
        <RollingFile name="FILE"
                     fileName="${LOG_FILE}"
                     filePattern="${LOG_FILE}.%d{yyyy-MM-dd}.gz">
            <PatternLayout pattern="${FILE_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

    </Appenders>

    <Loggers>

        <!-- Application classes - DEBUG and above -->
        <Logger name="com.avlija" level="DEBUG" additivity="false">
            <AppenderRef ref="CONSOLE"/>
            <AppenderRef ref="FILE"/>
        </Logger>

        <!-- Spring - INFO only -->
        <Logger name="org.springframework" level="WARN" additivity="false">
            <AppenderRef ref="CONSOLE"/>
            <AppenderRef ref="FILE"/>
        </Logger>
        <Logger name="org.springframework.web" level="INFO" additivity="false">
            <AppenderRef ref="CONSOLE"/>
            <AppenderRef ref="FILE"/>
        </Logger>

        <!-- SQL Server driver - suppress noise -->
        <Logger name="com.microsoft.sqlserver" level="WARN" additivity="false">
            <AppenderRef ref="FILE"/>
        </Logger>

        <!-- Root -->
        <Root level="INFO">
            <AppenderRef ref="CONSOLE"/>
            <AppenderRef ref="FILE"/>
        </Root>

    </Loggers>

</Configuration>